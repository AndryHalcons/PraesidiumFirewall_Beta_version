{
  "install_route": [
        {
          "source": "modern_format/modules/alias/backend/checks/system_data/default_forms/*",
          "destination": "/var/www/backend/checks/system_data/default_forms/"
        },
        {
          "source": "modern_format/modules/alias/backend/checks/system_data/default_tables_structure/*",
          "destination": "/var/www/backend/checks/system_data/default_tables_structure/"
        },
        {
          "source": "modern_format/modules/alias/initial_config/*",
          "destination": "/var/www/config/"
        },
        {
          "source": "modern_format/modules/alias/running_config/*",
          "destination": "/var/www/config_running/"
        },
        {
          "source": "modern_format/modules/alias/test/*",
          "destination": "/var/www/test/"
        },
        {
          "source": "modern_format/modules/alias/web/*",
          "destination": "/var/www/html/"
        }
    ],
      "permissions": [
        {
          "1": "modern_format/modules/alias/backend/checks/system_data/default_forms/*"
        }

    ]
}