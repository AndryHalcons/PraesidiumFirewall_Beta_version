{
  "install_route": [
        {
          "source": "modern_format/modules/monitor_session/backend/checks/check_sessions_contrack/*",
          "destination": "/var/www/backend/checks/check_sessions_contrack/"
        },
        {
          "source": "modern_format/modules/monitor_session/backend/checks/default_forms/*",
          "destination": "/var/www/backend/checks/system_data/default_forms/"
        },
        {
          "source": "modern_format/modules/monitor_session/backend/checks/default_tables_structure/*",
          "destination": "/var/www/backend/checks/system_data/default_tables_structure/"
        },
        {
          "source": "modern_format/modules/monitor_session/initial_config/*",
          "destination": "/var/www/config/"
        },
        {
          "source": "modern_format/modules/monitor_session/running_config/*",
          "destination": "/var/www/config_running/"
        },
        {
          "source": "modern_format/modules/monitor_session/test/*",
          "destination": "/var/www/test/"
        },
        {
          "source": "modern_format/modules/monitor_session/web/*",
          "destination": "/var/www/html/"
        }
    ]
}