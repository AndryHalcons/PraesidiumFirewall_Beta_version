{
  "install_route": [
        {
          "source": "modern_format/modules/policies/backend/checks/default_forms/*",
          "destination": "/var/www/backend/checks/system_data/default_forms/"
        },
        {
          "source": "modern_format/modules/policies/backend/checks/default_tables_structure/*",
          "destination": "/var/www/backend/checks/system_data/default_tables_structure/"
        },
        {
          "source": "modern_format/modules/policies/backend/commits/commit_task/*",
          "destination": "/var/www/backend/commits/commit_task/"
        },
        {
          "source": "modern_format/modules/policies/initial_config/*",
          "destination": "/var/www/config/"
        },
        {
          "source": "modern_format/modules/policies/running_config/*",
          "destination": "/var/www/config_running/"
        },
        {
          "source": "modern_format/modules/policies/test/*",
          "destination": "/var/www/test/"
        },
        {
          "source": "modern_format/modules/policies/web/*",
          "destination": "/var/www/html/"
        }
    ]
}