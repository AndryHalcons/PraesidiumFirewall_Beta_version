{
  "install_route": [
        {
          "source": "modern_format/modules/networking/backend/checks/default_forms/*",
          "destination": "/var/www/backend/checks/system_data/default_forms/"
        },
        {
          "source": "modern_format/modules/networking/backend/checks/default_tables_structure/*",
          "destination": "/var/www/backend/checks/system_data/default_tables_structure/"
        },
        {
          "source": "modern_format/modules/networking/backend/commits/commit_task/*",
          "destination": "/var/www/backend/commits/commit_task/"
        },
        {
          "source": "modern_format/modules/networking/backend/vendor/*",
          "destination": "/var/www/backend/vendor/"
        },
        {
          "source": "modern_format/modules/networking/initial_config/*",
          "destination": "/var/www/config/"
        },
        {
          "source": "modern_format/modules/networking/running_config/*",
          "destination": "/var/www/config_running/"
        },
        {
          "source": "modern_format/modules/networking/test/*",
          "destination": "/var/www/test/"
        },
        {
          "source": "modern_format/modules/networking/web/*",
          "destination": "/var/www/html/"
        }
    ]
}