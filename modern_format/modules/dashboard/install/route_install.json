{
  "install_route": [
        {
          "source": "modern_format/modules/dashboard/backend/checks/default_forms/*",
          "destination": "/var/www/backend/checks/system_data/default_forms/"
        },
        {
          "source": "modern_format/modules/dashboard/backend/checks/default_tables_structure/*",
          "destination": "/var/www/backend/checks/system_data/default_tables_structure/"
        },
        {
          "source": "modern_format/modules/dashboard/initial_config/*",
          "destination": "/var/www/config/"
        },
        {
          "source": "modern_format/modules/dashboard/running_config/*",
          "destination": "/var/www/config_running/"
        },
        {
          "source": "modern_format/modules/dashboard/test/*",
          "destination": "/var/www/test/"
        },
        {
          "source": "modern_format/modules/dashboard/web/*",
          "destination": "/var/www/html/"
        }
    ]
}