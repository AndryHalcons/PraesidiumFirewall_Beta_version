{
    "squid": {
        "url_policies": [
            {
                "rule": {
                    "id": "1",
                    "position": 1,
                    "enable": "true",
                    "name": "Deny unsafe http ports",
                    "action": "deny",
                    "options": "",
                    "negate_ip_addr": "",
                    "ip_addr_group": "",
                    "negate_profile": "true",
                    "profile": "port_Profile_HTTP",
                    "description": "It does not allow HTTP navigation through ports that are not in the profile."
                }
            },
            {
                "rule": {
                    "id": "2",
                    "position": 2,
                    "enable": "true",
                    "name": "Deny unsafe Https ports",
                    "action": "deny",
                    "options": "CONNECT",
                    "negate_ip_addr": "",
                    "ip_addr_group": "",
                    "negate_profile": "true",
                    "profile": "port_Profile_HTTPS",
                    "description": "It does not allow navigation through ports that are not in the profile, it uses CONNECT to indicate that it is HTTPS"
                }
            },
            {
                "rule": {
                    "id": "3",
                    "position": 3,
                    "enable": "true",
                    "name": "My Example url policy 1",
                    "action": "deny",
                    "options": "",
                    "negate_ip_addr": "",
                    "ip_addr_group": "Private-networks",
                    "negate_profile": "",
                    "profile": "url_profile_1",
                    "description": "It denies web traffic to the domains contained in the profile."
                }
            },
            {
                "rule": {
                    "id": "4",
                    "position": 4,
                    "enable": "true",
                    "name": "My Example url policy 2",
                    "action": "deny",
                    "options": "",
                    "negate_ip_addr": "",
                    "ip_addr_group": "Private-networks",
                    "negate_profile": "",
                    "profile": "url_profile_2",
                    "description": "It denies web traffic to the domains contained in the profile."
                }
            },
            {
                "rule": {
                    "id": "5",
                    "position": 5,
                    "enable": "true",
                    "name": "Allow All",
                    "action": "allow",
                    "options": "",
                    "negate_ip_addr": "",
                    "ip_addr_group": "all",
                    "negate_profile": "",
                    "profile": "",
                    "description": "It allows all traffic that has not been denied in the previous rules."
                }
            }
        ],
        "url_profile": [
            {
                "rule": {
                    "id": "1",
                    "name": "url_profile_1",
                    "type": "dstdomain",
                    "file": "my_domains_list_1_2025-05-17_15-06-45.txt"
                }
            },
            {
                "rule": {
                    "id": "2",
                    "name": "url_profile_2",
