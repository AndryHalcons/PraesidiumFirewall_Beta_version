{
    "squid":{
        "url_policies": [
            {
                "rule": {
                    "id": "1",
                    "action": "accept",
                    "ip_addr_group": "Private-networks",
                    "profile": "1my_profile1"
                    
                }
            },
            {
                "rule": {
                    "id": "2",
                    "action": "accept",
                    "ip_addr_group": "Private-networks",
                    "profile": "2my_profile2"
                    
                }
            }
        ],
        "url_profile": [
            {
                "rule": {
                    "id": "1",
                    "name": "my_profile1_",
                    "type": "ssl::server_name",
                    "file": "myfile1"
                }
            },
            {
                "rule": {
                    "id": "2",
                    "name": "my_profile_2",
                    "type": "ssl::server_name",
                    "file": "myfile2"
                }
            }
        ],
        "url_listen_ports": [
            {
                "rule": {
                    "id": "1",
                    "port": "25"
                }
            },
            {
                "rule": {
                    "id": "2",
                    "port": "443"
                }
            }
        ]
    }
}