{
    "nftables": [
        {
            "metainfo": {
                "version": "1.0.9",
                "release_name": "Old Doc Yak #3",
                "json_schema_version": 1
            }
        },
        {
            "table": {
                "family": "inet",
                "name": "filter",
                "handle": 1
            }
        },
        {
            "chain": {
                "family": "inet",
                "table": "filter",
                "name": "input",
                "handle": 1,
                "type": "filter",
                "hook": "input",
                "prio": 0,
                "policy": "accept"
            }
        },
        {
            "chain": {
                "family": "inet",
                "table": "filter",
                "name": "output",
                "handle": 2,
                "type": "filter",
                "hook": "output",
                "prio": 0,
                "policy": "accept"
            }
        },
        {
            "chain": {
                "family": "inet",
                "table": "filter",
                "name": "FORWARDING",
                "handle": 3,
                "type": "filter",
                "hook": "forward",
                "prio": 0,
                "policy": "accept"
            }
        },
        {
            "table": {
                "family": "inet",
                "name": "nat",
                "handle": 2
            }
        },
        {
            "chain": {
                "family": "inet",
                "table": "nat",
                "name": "POSTROUTING",
                "handle": 4,
                "type": "nat",
                "hook": "postrouting",
                "prio": 100,
                "policy": "accept"
            }
        },
        {
            "chain": {
                "family": "inet",
                "table": "nat",
                "name": "PREROUTING",
                "handle": 5,
                "type": "nat",
                "hook": "prerouting",
                "prio": -100,
                "policy": "accept"
            }
        },
        {
            "rule": {
                "family": "inet",
                "table": "nat",
                "chain": "PREROUTING",
                "position": 1,
                "id": 1,
                "name": "ping my server",
                "expr": [
                    {
                        "match": {
                            "op": "==",
                            "left": {
                                "payload": {
                                    "protocol": "ip",
                                    "field": "protocol"
                                }
                            },
                            "right": "icmp"
                        }
                    },
                    {
                        "match": {
                            "op": "!=",
                            "left": {
                                "payload": {
                                    "protocol": "ip",
                                    "field": "saddr"
                                }
                            },
                            "right": {
                                "set": [
                                    {
                                        "prefix": {
                                            "addr": "10.0.0.0",
                                            "len": 8
                                        }
                                    },
                                    {
                                        "prefix": {
                                            "addr": "172.16.0.0",
                                            "len": 12
                                        }
                                    },
                                    {
                                        "prefix": {
                                            "addr": "192.168.0.0",
                                            "len": 16
                                        }
                                    }
                                ]
                            }
                        }
                    },
                    {
                        "match": {
                            "op": "==",
                            "left": {
                                "payload": {
                                    "protocol": "ip",
                                    "field": "daddr"
                                }
                            },
                            "right": "192.168.1.1"
                        }
                    },
                    {
                        "match": {
                            "op": "==",
                            "left": {
                                "ct": {
                                    "key": "state"
                                }
                            },
                            "right": {
                                "set": [
                                    "established",
                                    "related",
                                    "new"
                                ]
                            }
                        }
                    },
                    {
                        "counter": {
                            "packets": 0,
                            "bytes": 0
                        }
                    },
                    {
                        "log": {
                            "prefix": "",
                            "group": 0
                        }
                    },
                    {
                        "dnat": {
                            "addr": "10.0.50.10"
                        }
                    }
                ],
                "comment": "id='1',name='ping my server'"
            }
        }
    ]
}