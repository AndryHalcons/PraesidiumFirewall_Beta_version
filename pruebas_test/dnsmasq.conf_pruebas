# Desactivar el servidor DNS completamente
port=0                  # Desactiva el servicio DNS (no escucha en el puerto 53)
no-resolv               # No lee /etc/resolv.conf para obtener servidores DNS
no-hosts                # No usa /etc/hosts para resolver nombres
no-poll                 # No monitorea cambios en resolv.conf

# Interfaces activas (declaramos todas las interfaces que usará dnsmasq)
interface=eno1          # Primera interfaz con red 192.168.1.0/24
interface=eno2          # Segunda interfaz con red 10.0.0.0/24

# Configuración DHCP para eno1 (192.168.1.0/24)
dhcp-range=eno1,192.168.1.50,192.168.1.150               	   # Rango de IPs
dhcp-option=eno1,option:lease-time,43200					   # duración del lease
dhcp-option=eno1,option:router,192.168.1.1                     # Puerta de enlace que se anuncia por DHCP
dhcp-option=eno1,option:dns-server,1.1.1.1,8.8.8.8             # IP del servidor DNS que se entrega por DHCP
dhcp-option=eno1,option:ntp-server,192.168.1.1                 # Servidor NTP para sincronización horaria
dhcp-option=eno1,option:netmask,255.255.255.0                  # Máscara de red definida como opción DHCP

# Configuración DHCP para eno2 (10.0.0.0/24)
dhcp-range=eno2,10.0.0.50,10.0.0.150                      	   # Rango de IPs 
dhcp-option=eno2,option:lease-time,43200					   # duración del lease
dhcp-option=eno2,option:router,10.0.0.1                        # Puerta de enlace para esta red
dhcp-option=eno2,option:dns-server,1.1.1.1,8.8.8.8             # DNS que se anuncia por DHCP
dhcp-option=eno2,option:ntp-server,10.0.0.1                    # Servidor NTP para esta red
dhcp-option=eno2,option:netmask,255.255.255.0                  # Máscara de red definida como opción DHCP

# Archivo donde se guardarán los leases activos
dhcp-leasefile=/var/lib/misc/dnsmasq.leases